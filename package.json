{
  "name": "deter_core",
  "version": "1.0.0",
  "type": "module",
  "description": "Discord bot for syncing forum discussions to database.",
  "author": "Star Inc.",
  "homepage": "https://starinc.xyz",
  "license": "MIT",
  "main": "app.ts",
  "scripts": {
    "dev": "bun --watch app.ts",
    "start": "bun app.ts",
    "lint": "npx lint-staged",
    "lint:es": "eslint \"*.ts\" \"src/**/*.ts\"",
    "lint:es:fix": "eslint \"*.ts\" \"src/**/*.ts\" --fix",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.ts": "eslint"
  },
  "dependencies": {
    "@langchain/core": "^1.1.38",
    "@langchain/openai": "^1.4.1",
    "@tavily/core": "^0.7.2",
    "commander": "^12.0.0",
    "discord.js": "^14.13.0",
    "dotenv": "^16.0.3",
    "got": "^14.3.0",
    "langchain": "^1.2.39",
    "mysql2": "^3.7.1",
    "openweather-api-node": "^3.1.5",
    "quickjs-emscripten": "^0.32.0",
    "sequelize": "^6.35.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.4.4",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.17.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-jsdoc": "^48.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^13.2.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
