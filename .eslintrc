{
  "plugins": [
      "jsdoc",
      "@typescript-eslint"
  ],  
  "extends": [
    "eslint:recommended",
    "google",
    "plugin:@typescript-eslint/recommended"
  ],
  "parser": "@typescript-eslint/parser",
  "rules": {
    "jsdoc/no-undefined-types": 1,
    "linebreak-style": 1,
    "indent": [
      "error",
      4
    ],
    "quotes": [
      "error",
      "double"
    ],
    "@typescript-eslint/no-explicit-any": "off",
    "@typescript-eslint/no-unused-vars": ["error", {
      "argsIgnorePattern": "^_",
      "varsIgnorePattern": "^_"
    }],
    "require-jsdoc": "off",
    "valid-jsdoc": "off",
    "max-len": ["error", {
      "code": 100,
      "ignoreUrls": true,
      "ignoreStrings": true
    }]
  },
  "env": {
    "es6": true,
    "node": true,
    "browser": false
  },
  "parserOptions": {
    "sourceType": "module",
    "ecmaVersion": 2023,
    "project": "./tsconfig.json"
  }
}